{
  "name": "gridpulse-worker",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 execute gridpulse --local --file=src/db/schema.sql",
    "db:migrate:remote": "wrangler d1 execute gridpulse --remote --file=src/db/schema.sql",
    "db:seed:fetch": "node scripts/seed-areas.js",
    "db:seed:local": "wrangler d1 execute gridpulse --local --file=src/db/seed-areas.sql",
    "db:seed:remote": "wrangler d1 execute gridpulse --remote --file=src/db/seed-areas.sql",
    "poll:all": "node scripts/poll-all.js"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.0",
    "typescript": "~5.9.3",
    "wrangler": "^3.90.0"
  }
}
